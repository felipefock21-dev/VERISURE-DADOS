# =============================================================================
# OAuth 2.0 - OBRIGATÓRIO para "Conectar ao Google Drive" (evita Erro 401 invalid_client)
# Crie um cliente em: https://console.cloud.google.com/ → APIs & Services → Credentials
# Tipo: "Web application" | Redirect URI: ver abaixo
# =============================================================================
OAUTH_CLIENT_ID=seu_client_id_xxx.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=GOCSPX-xxx

# Onde o app está rodando (redirect URI = DEPLOY_URL/oauth2callback)
# Localhost (padrão do código; pode omitir ou deixar assim):
DEPLOY_URL=http://localhost:5000
# Futuro no Render: defina no painel do Render
# DEPLOY_URL=https://seu-app.onrender.com

# Pasta do Drive para upload dos relatórios (opcional)
# DRIVE_FOLDER_ID=id_da_pasta

# =============================================================================
# Outros (opcional)
# =============================================================================
# DADOS_IDENTIFICADOR_SHEET_ID=
# SEMANAL_OFICIAL_FILE_ID=
FLASK_ENV=production
PYTHONUNBUFFERED=1
